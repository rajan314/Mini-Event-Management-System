{
  "info": {
    "name": "Mini Event Management System",
    "_postman_id": "event-booking-system-v1",
    "description": "Complete Postman collection for the Mini Event Management System API.\n\nBase URL: http://localhost:3000\n\nImport this collection and set the `baseUrl` variable in Collection Variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "bookingCode",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the 'Book a Ticket' request."
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verify the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Upcoming Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Returns all future events ordered by date."
          },
          "response": []
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node.js Workshop\",\n  \"description\": \"Hands-on workshop for beginner to intermediate Node.js.\",\n  \"date\": \"2025-10-01T10:00:00\",\n  \"capacity\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Create a new event with title, optional description, date (must be future), and capacity."
          },
          "response": []
        },
        {
          "name": "Create Event – Validation Error (missing fields)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Demonstrates 422 validation error response."
          },
          "response": []
        },
        {
          "name": "Record Attendance",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure bookingCode variable is set before running this request"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"{{bookingCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            },
            "description": "Check-in a user using their booking_code. Returns tickets_booked count."
          },
          "response": []
        },
        {
          "name": "Record Attendance – Invalid Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"00000000-0000-0000-0000-000000000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            },
            "description": "Demonstrates 404 when booking code does not match the event."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Book a Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.booking_code) {",
                  "  pm.collectionVariables.set('bookingCode', json.data.booking_code);",
                  "  console.log('bookingCode saved:', json.data.booking_code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1,\n  \"tickets_count\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            },
            "description": "Book tickets for a user. The `booking_code` in the response is automatically saved to the `bookingCode` collection variable."
          },
          "response": []
        },
        {
          "name": "Book a Ticket – Duplicate (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1,\n  \"tickets_count\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            },
            "description": "Run after 'Book a Ticket' to see the 409 duplicate error."
          },
          "response": []
        },
        {
          "name": "Book a Ticket – User Not Found (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 9999,\n  \"event_id\": 1,\n  \"tickets_count\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            },
            "description": "Demonstrates 404 when user_id does not exist."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "bookings"]
            },
            "description": "Retrieve all bookings for user with ID 1."
          },
          "response": []
        },
        {
          "name": "Get User Bookings – User Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/9999/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "9999", "bookings"]
            },
            "description": "Demonstrates 404 when user does not exist."
          },
          "response": []
        }
      ]
    }
  ]
}
